//clase computadora ----------------------------------------------------------------------------------------------------
public class Computadora {
    private String marca,modelo,procesador,marcagrafica,modelografica,vram;
    private int hilos, ram,almacenamiento,precio,ganancia;
    private float frecuencia;

    public Computadora(String marca,String modelo, String procesador, String marcagrafica,String modelografica, String vram,
                       int hilos, int ram, int almacenamiento, int precio, int ganancia, float frecuencia)
    {
        this.marca=marca;this.modelo=modelo;this.procesador=procesador;this.marcagrafica=marcagrafica;this.modelografica=modelografica;this.vram=vram;
        this.hilos=hilos;this.ram=ram;this.almacenamiento=almacenamiento;this.precio=precio;this.ganancia=ganancia;this.frecuencia=frecuencia;
    }
    public String getMarca(){return marca;}
    public void setMarca(String marca){this.marca=marca;}

    public String getModelo(){return modelo;}
    public void setModelo(String modelo){this.modelo=modelo;}
    
    public String getProcesador(){return procesador;}
    public void setProcesador(String procesador){this.procesador=procesador;}
    
    public String getMarcagrafica(){return marcagrafica;}
    public void setMarcagrafica(String marcagrafica){this.marcagrafica=marcagrafica;}
    
    public String getModelografica(){return modelografica;}
    public void setModelografica(String modelografica){this.modelografica=modelografica;}

    public String getVram(){return vram;}
    public void setVram(String vram){this.vram=vram;}

    public int getRam(){return ram;}
    public void setRam(int ram){this.ram=ram;}

    public int getHilos(){return hilos;}
    public void setHilos(int hilos){this.hilos=hilos;}


    public int getAlmacenamiento(){return almacenamiento;}
    public void setAlmacenamiento(int almacenamiento){this.almacenamiento=almacenamiento;}

    public int getPrecio(){return precio;}
    public void setPrecio(int precio){this.precio=precio;}

    public int getGanancia(){return ganancia;}
    public void setGanancia(int ganancia){this.ganancia=ganancia;}

    public float getFrecuencia(){return frecuencia;}
    public void setFrecuencia(float frecuencia){this.frecuencia=frecuencia;}
    

}
