import java.util.Random;
import java.util.Scanner;

public class EnumEjercicio2
{
    static Boolean verificacion;
    static Scanner read = new Scanner(System.in);
    static String eleccion;
    static String compu;
    static int Rondas;
    static int Usuario,Maquina;
    public static void main()
    {
        System.out.println("-----PIEDRA PAPEL O TIJERA 2 (Revolution) \n-----AL MEJOR DE 3(idea robada a Avril)");
        //2) Realizar un juego de piedra papel o tijeras utilizando ENUM y Funciones

        do {
            IngresarDatos();//se pide la eleccionde usuario
            Comparacion();//se define la funcion "JugadaCompu" como variable local y se define ganador de cada caso
            GanadorRonda();//se define el ganador y se da el premio,deam
        }while (Rondas<3);
        GanadorFinal();
    }
    public static void GanadorFinal()
    {
        if (Maquina<Usuario){System.out.println("\nGanaste la partida "+ Usuario +" - "+ Maquina);}
        else {System.out.println("\nPerdiste la partida "+Maquina+" - "+Usuario+" :(");}
    }
    public static void GanadorRonda()
    {
        int resultado = Comparacion();
        switch (resultado)
        {
            case 0: System.out.println("La maquina elijió "+compu);System.out.println("La ronda fue un empate");break;
            case 1: System.out.println("La maquina elijió "+compu);System.out.println("Perdiste la ronda, buuu");Rondas+=1;Maquina+=1;break;
            case 2: System.out.println("La maquina elijió "+compu);System.out.println("ganaste la ronda bro");Rondas+=1;Usuario+=1;break;
        }
    }
    public static int Comparacion()
    {
        compu = JugadaCompu();
        switch (eleccion)
        {
            case "PIEDRA":
                if (compu.equals("PIEDRA")){return 0;}//empate
                else if (compu.equals("PAPEL")){return 1;}//perdio
                else if (compu.equals("TIJERA")){return 2;}//gano
                break;
            case "PAPEL":
                if (compu.equals("PIEDRA")){return 2;}//gano
                else if (compu.equals("PAPEL")){return 0;}//empate
                else if (compu.equals("TIJERA")){return 1;}//perdio
                break;
            case "TIJERA":
                if (compu.equals("PIEDRA")){return 1;}//perdio
                else if (compu.equals("PAPEL")){return 2;}//gano
                else if (compu.equals("TIJERA")){return 0;}//empate
                break;
        }
        return 3;//si algo sale mal¿?
    }

    public static String IngresarDatos()
    {
        do{
            System.out.println("--------------------\nPiedra papel o tijeras?");
            eleccion = read.next().toUpperCase();
            if(eleccion.equals("PIEDRA")||eleccion.equals("PAPEL")||eleccion.equals("TIJERA")){verificacion=true;}
            else{verificacion=false;System.out.println("Datos no validos, volver a ingresar.\n");}
        }while(!verificacion);

        return eleccion;
    }
    public static String JugadaCompu()
    {
        Random random = new Random();
        int x = random.nextInt(3);
        switch (x){
            case 0:return Componentes.PIEDRA.toString();
            case 1:return Componentes.PAPEL.toString();
            case 2:return Componentes.TIJERA.toString();
        }
        return "nada";
    }
    public enum Componentes
    {
        PIEDRA,PAPEL,TIJERA;
    }
}
