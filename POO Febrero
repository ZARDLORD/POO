using System.Text.Json;
namespace POO_Feb
{
    internal class Program
    {
        static Producto[] arrayproductos = new Producto[0];
        static void Main(string[] args)
        {
            CargarProductos();
            CargarMovimientos();
            var opciones = new JsonSerializerOptions { WriteIndented = true,PropertyNamingPolicy=JsonNamingPolicy.CamelCase };
            Console.WriteLine(JsonSerializer.Serialize(arrayproductos,opciones));
            MayorStock();
        }
        static void CargarProductos()
        {
            StreamReader archivop = new StreamReader("productos.txt");
            string[] productos = archivop.ReadLine().Split("#");
            for(int i=0;i<productos.Length;i+=2) 
            {
                string a = productos[i];
                string b = productos[i + 1];
                Array.Resize(ref arrayproductos, arrayproductos.Length + 1);
                arrayproductos[arrayproductos.Length - 1] = new Producto(a, b);
            }

        }
        static void CargarMovimientos()
        {
            string id="";
            int indice = 0;
            int nota = 0;
            string[] archivom = File.ReadAllLines("movimientos.txt");
            for(int i = 0; i < archivom.Length; i++)
            {
                string x = archivom[i];
                if (x.StartsWith("ART-"))
                {
                    indice = i;
                    id = x;
                }
                else
                {if(BuscarID(id)!=-1)
                    arrayproductos[BuscarID(id)].Registrar(int.Parse(x));
                }
            }
        }
        static int BuscarID(string id)
        {
            for(int i=0;i<arrayproductos.Length;i++)
            {
                if (arrayproductos[i].SKU == id)
                {
                    return i;
                }
            }
            return -1;
        }
        static void MayorStock()
        {
            int mejor = 0;
            int indice = 0;
            for(int i = 0; i < arrayproductos.Length; i++)
            {
                if (mejor < arrayproductos[i].StockTotal())
                {
                    mejor = arrayproductos[i].StockTotal();
                    indice = i;
                }
            }
            Console.WriteLine($"el producto con mayor stock es el {arrayproductos[indice].Nombre} con un stock total de {arrayproductos[indice].StockTotal()}");
        }
    }
}

