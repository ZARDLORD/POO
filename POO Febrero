using System;
using System.Collections.Generic;
using System.Linq;
using System.Text;
using System.Threading.Tasks;

namespace POO_Feb
{
    internal class Producto
    {
        private string sku;
        private string nombre;
        private int[] movimientos = new int[] { 0, 0, 0, 0, 0, 0 };
        public Producto(string sku,string nombre)
        {
            SKU = sku;
            Nombre = nombre;
        }
        public string SKU { get=>sku;set=>sku="ART-"+value;}
        public string Nombre { get => nombre; set => nombre = value.Length > 15 ? nombre.Substring(0, 15) : value; }
        public int[] Movimientos { get => movimientos; set => movimientos = value; }
        public void Registrar(int cantidad)
        {
            for(int i=0; i<movimientos.Length;i++) 
            {
                if (movimientos[i] == 0)
                {
                    movimientos[i] = cantidad;
                    return;
                }
            }
        }
        public int StockTotal()
        {
            int suma = 0;
            for(int i=0;i<movimientos.Length;i++)
            {
                suma += movimientos[i];
            }
            return suma;
        }
    }
}
