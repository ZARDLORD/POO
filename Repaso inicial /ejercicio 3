import java.util.Scanner;
public class Main
{
  public static void main(String[]args) {
    Scanner read = new Scanner(System.in);


    System.out.println("Ingrese la cantidad de numeros primos");
    int n = read.nextInt();
    System.out.println("Ingrese desde que numero quiere empezar");
    int x = read.nextInt();
    int cont =0;
    for (int i=0;i<n;i++)
    {
      while (cont<n)
      {
        if(x>4)
        {
          if (EsPrimo(x))
          {
            System.out.println(x + " es primo");
            cont++;
          }
          x++;
        }else
        {
          if (x==2){System.out.println(x +" es primo!");cont++;}
          x++;
        }
      }
    }
  }
  public static boolean EsPrimo(int numero)
  {
    for (int i=2;i<numero/2;i++)
    {
      if(numero%i==0){return false;} //no es primo
    }
    return true;
  }
}
